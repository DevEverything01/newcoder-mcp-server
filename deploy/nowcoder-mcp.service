[Unit]
Description=Nowcoder MCP Server
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/root/nowcoder-mcp-server
Environment=TRANSPORT=https
Environment=PORT=3001
Environment=HOST=0.0.0.0
ExecStart=/usr/bin/node dist/index.js
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
